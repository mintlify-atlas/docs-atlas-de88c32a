  "keyFeatures": [
    "Clerk authentication with Google OAuth and email/password",
    "CRUD operations for personal notes with user isolation",
    "Rate limiting with Upstash Redis (30 reads/10s, 10 writes/10s)",
    "Zod schema validation for type-safe data handling",
    "Turso edge database with Drizzle ORM",
    "Real-time search with match highlighting",
    "Responsive design with Tailwind CSS 4",
    "Protected routes with middleware"
  ],
  "publicApiSurface": [
    "GET /api/notes - List all notes for authenticated user",
    "POST /api/notes - Create a new note",
    "PUT /api/notes/[id] - Update existing note",
    "DELETE /api/notes/[id] - Delete a note",
    "/dashboard - Protected dashboard page",
    "/ - Public landing page with authentication"
  ]
